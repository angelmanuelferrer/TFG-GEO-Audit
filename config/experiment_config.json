{
  "version": "1.1.0",
  "target_url": "https://programamos.es",
  "target_brand": "Programamos",

  "discovery": {
    "model": "gemini-2.5-flash",
    "provider": "google",
    "grounding": "google_search"
  },

  "rag_simulator": {
    "model": "gemini-2.5-flash",
    "temperature": 0.0,
    "max_tokens": 2000,
    "response_format": "json_object",
    "mode": "agent"
  },

  "embeddings": {
    "model": "intfloat/multilingual-e5-large",
    "dimensions": 1024,
    "provider": "local",
    "fallback": {
      "model": "text-embedding-3-small",
      "dimensions": 1536,
      "provider": "openai"
    }
  },

  "chunking": {
    "default_chunk_size_tokens": 256,
    "default_overlap_tokens": 64,
    "faq_chunk_size_tokens": 256,
    "faq_overlap_tokens": 64,
    "separators": ["\n## ", "\n### ", "\n\n", "\n", ". ", " "]
  },

  "retrieval": {
    "top_k": 5,
    "search_type": "similarity"
  },

  "live_evaluation": {
    "engines": ["claude"],
    "claude_model": "claude-sonnet-4-5-20250929"
  },

  "sentiment": {
    "model": "gpt-4o-mini",
    "temperature": 0.0
  },

  "crawler": {
    "request_delay": 1.0,
    "timeout": 10,
    "max_retries": 3,
    "respect_robots_txt": true,
    "target": {
      "enabled": true,
      "max_pages": null,
      "exclude_patterns": ["/tag/", "/author/", "/wp-admin/", "/wp-content/", "/sitemap"],
      "priority": "pages_first"
    },
    "competitor": {
      "enabled": true,
      "max_pages": 100,
      "priority": "discovered_urls_first",
      "exclude_patterns": ["/tag/", "/category/", "/author/"]
    },
    "fallback": {
      "bfs_enabled": true,
      "max_depth": 2,
      "same_domain_only": true
    }
  }
}

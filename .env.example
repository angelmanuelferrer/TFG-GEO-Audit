# === GEO-Audit System: Variables de Entorno ===
# Copiar a .env y rellenar con valores reales

# OpenAI (RAG Judge + métricas)
OPENAI_API_KEY=sk-...

# Google (Gemini + PageSpeed)
GOOGLE_API_KEY=AI...
GOOGLE_PAGESPEED_KEY=AI...

# Tavily (búsqueda web)
TAVILY_API_KEY=tvly-...

# Notion (reporting)
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=...

# User Agent para scraping
USER_AGENT=GeoAuditBot/1.0 (TFG Research)
